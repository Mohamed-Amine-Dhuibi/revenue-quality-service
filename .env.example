# Copy to .env and set a real key before running. .env is git-ignored.
# All variables are prefixed with RQS_.

# Required: the API key clients must send in the X-API-Key header.
RQS_API_KEY=change-me-to-a-long-random-secret

# Optional overrides (defaults shown):
# RQS_API_KEY_HEADER=X-API-Key
# RQS_CURRENCY=SAR
# RQS_MAX_UPLOAD_BYTES=10485760
